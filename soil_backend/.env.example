# ---------------------------------------------------------------------------
# Soil Management Backend - environment configuration
# Copy to ".env" and adjust. Never commit the real .env or credentials.
# ---------------------------------------------------------------------------

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# CORS (browser tooling only; mobile clients send no Origin)
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=

# Firebase Admin — path to a service-account JSON file.
# Required for the protected /api/v1/soil-management/ endpoint.
FIREBASE_CREDENTIALS=firebase-service-account.json

# Optional: mirror generated advisories to a server-side Firestore audit
# collection. Off by default; Flutter remains the source of truth.
FIRESTORE_AUDIT=False
